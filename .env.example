APP_ENV=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/knowledge_agent
POSTGRES_PASSWORD=postgres
REDIS_HOST=redis
REDIS_PASSWORD=
RATE_LIMIT_ENABLED=false
JWT_SECRET=replace-with-a-long-random-secret
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
CHAT_MODEL=deepseek-chat
EMBEDDING_MODEL=
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_DIMENSIONS=1536
FILE_STORAGE_PATH=/app/uploads
WEB_CRAWL_USER_AGENT=PersonalKnowledgeAgent/0.1
SYNC_INTERVAL_MINUTES=30
GIT_IMPORT_ROOT=/app/git-imports
GIT_IMPORT_HOST_ROOT=..
BACKGROUND_WORKER_ENABLED=true
BACKGROUND_WORKER_POLL_SECONDS=2
BACKGROUND_TASK_STALE_SECONDS=300
GRAPH_EXTRACTION_ENABLED=true
GRAPH_EXTRACTION_MAX_CHUNKS_PER_TASK=20
ADMIN_USERNAME=
ADMIN_PASSWORD=
VISITOR_ACCESS_KEY=

# Production checklist:
# APP_ENV=production
# RATE_LIMIT_ENABLED=true
# JWT_SECRET=<generate-a-long-random-secret>
# POSTGRES_PASSWORD=<generate-a-strong-database-password>
# REDIS_PASSWORD=<generate-a-strong-redis-password>
# LLM_API_KEY=<deepseek-api-key>
# EMBEDDING_API_KEY=<github-models-or-embedding-provider-token>
# ADMIN_USERNAME=<admin-name>
# ADMIN_PASSWORD=<admin-password>
# VISITOR_ACCESS_KEY=<visitor-site-key>
